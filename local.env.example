# Copy to local.env and fill in for your router.
# local.env is gitignored.

# SSH user on the Mikrotik (must have key auth enabled).
ROUTER_USER=admin

# Mikrotik address as reachable from the build host.
ROUTER_HOST=192.0.2.1

# Disk slot label on the Mikrotik (as shown in `/disk print`).
# This is the path-prefix used for all asset paths on the router.
STORAGE_VOLUME=usbstorage

# GHCR namespace for the netbootxyz container image you maintain.
# Used only by docs — you build via your own GH Actions workflow.
GHCR_NAMESPACE=YOUR-GH-USER
